{ lib }:
''
    # Cursor
    cursor_size=18
    cursor_theme=Bibata-Modern-Ice

    # Windows
    borderpx=0
    gappoh=5
    gappov=5
    border_radius=10
    unfocused_opacity=0.92

    # Blur
    blur=1
    blur_layer=0
    blur_params_radius=25
    blur_params_num_passes=1
    blur_params_noise=0.01
    blur_params_brightness=1.25
    blur_params_contrast=1.0
    blur_optimized=1

    # Animations
    animation_type_open=zoom
    animation_type_close=zoom
    layer_animation_type_open=zoom
    layer_animation_type_close=zoom

    animation_duration_move=500
    animation_duration_open=400
    animation_duration_tag=300
    animation_duration_close=300
    animation_duration_focus=300
''
